# MariaDB on Synology (host network — use 127.0.0.1)
DATABASE_URL=mysql://photodropper:changeme@127.0.0.1:3306/photodropper

NEXTAUTH_SECRET=generate-a-long-random-secret
# Public URL — must match what you open in the browser (reverse proxy or LAN)
NEXTAUTH_URL=https://photodropper.0x0001.org
AUTH_TRUST_HOST=true

ADMIN_PASSWORD=changeme

PORT=3011
# QR codes and guest links (/action) — same public URL as NEXTAUTH_URL when using reverse proxy
PUBLIC_BASE_URL=https://photodropper.0x0001.org

PHOTO_UPLOAD_PATH=/data/photos
PHOTOS_HOST_DIR=/volume1/docker-projects/photodropper/photos

NEXT_PUBLIC_PLAYLIST_POLL_INTERVAL_MS=5000

# FamilyAlbum export (Phase C — optional for now)
FAMILYALBUM_URL=https://album.0x0001.org
FAMILYALBUM_IMPORT_KEY=
