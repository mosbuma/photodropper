# Synology production .env — copy to .env on the NAS:
#   cp .env.synology.example .env
#
# App listens on PORT (3011) with host network. Reverse proxy terminates HTTPS at
# https://photodropper.0x0001.org → http://127.0.0.1:3011

DATABASE_URL=mysql://photodropper:PASSWORD@127.0.0.1:3306/photodropper

NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://photodropper.0x0001.org
AUTH_TRUST_HOST=true

ADMIN_PASSWORD=changeme

PORT=3011
PUBLIC_BASE_URL=https://photodropper.0x0001.org

PHOTO_UPLOAD_PATH=/data/photos
PHOTOS_HOST_DIR=/volume1/docker-projects/photodropper/photos

NEXT_PUBLIC_PLAYLIST_POLL_INTERVAL_MS=5000

FAMILYALBUM_URL=https://album.0x0001.org
FAMILYALBUM_IMPORT_KEY=

CONTAINER_UID=0
CONTAINER_GID=0
